# Luthn local self-host defaults.
#
# Copy to .env or run ./scripts/install-local.sh to create .env automatically.
# Keep real credentials and production token digests out of Git.

POSTGRES_DB=luthn
POSTGRES_USER=luthn
POSTGRES_HOST_AUTH_METHOD=trust

# Used by Docker Compose services.
LUTHN_DOCKER_CONNECTION_STRING="Host=postgres;Port=5432;Database=luthn;Username=luthn"

# Used by host-side dotnet tools during install-local.sh.
LUTHN_LOCAL_CONNECTION_STRING="Host=localhost;Port=5432;Database=luthn;Username=luthn"

# Classification is blocked until an operator configures a provider.
# Explicit development/test-only mock use requires both values below.
Luthn__Classification__Provider=unconfigured
Luthn__Classification__AllowMock=false

Luthn__Database__EnableRetries=true
Luthn__Database__MaxRetryCount=5
Luthn__Database__MaxRetryDelaySeconds=10
Luthn__OperatorConfig__Directory=/var/lib/luthn/operator
Luthn__Host__RequestTimeoutSeconds=65

# Local self-host agent API auth.
# scripts/install-local.sh fills these values in .env automatically.
# Do not copy local token values into production.
# LUTHN_SERVICE_VALUE=<generated local bearer token>
# Luthn__Auth__RequireServiceToken=true
# Luthn__Auth__Tokens__0__Name=local-agent
# Luthn__Auth__Tokens__0__Sha256Digest=sha256:<generated digest>
# Luthn__Auth__Tokens__0__Scopes__0=agent.read
# Luthn__Auth__Tokens__0__Scopes__1=agent.write.summary
# Luthn__Auth__Tokens__0__Scopes__2=memory.write
# Luthn__Auth__Tokens__0__Scopes__3=memory.read
# Luthn__Auth__Tokens__0__Scopes__4=classification.preview
# Luthn__Auth__Tokens__0__Scopes__5=agent.connection.read
# Luthn__Auth__Tokens__0__Scopes__6=agent.connection.write
# Luthn__Auth__Tokens__0__Scopes__7=external-publication.read
# Luthn__Auth__Tokens__0__Scopes__8=external-publication.write
