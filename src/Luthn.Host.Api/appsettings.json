{
  "ConnectionStrings": {
    "LuthnDb": "Host=localhost;Port=5432;Database=luthn;Username=luthn"
  },
  "Luthn": {
    "Classification": {
      "Provider": "mock",
      "AllowMock": true,
      "Runtime": {
        "TimeoutSeconds": 30,
        "MaxAttempts": 2,
        "RetryDelayMilliseconds": 200
      }
    },
    "Database": {
      "EnableRetries": true,
      "MaxRetryCount": 5,
      "MaxRetryDelaySeconds": 10
    },
    "Memory": {
      "AutomaticTurnRetentionDays": 30,
      "AutomaticTurnCleanupEnabled": true,
      "AutomaticTurnCleanupIntervalMinutes": 60,
      "AutomaticTurnCleanupBatchSize": 100
    },
    "Host": {
      "EnableForwardedHeaders": false,
      "TrustAllForwardedHeaders": false,
      "EnforceHttps": false,
      "RequestTimeoutSeconds": 65,
      "RateLimitPermitLimit": 600,
      "RateLimitWindowSeconds": 60
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
