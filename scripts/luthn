#!/usr/bin/env bash
set -euo pipefail

project_name="${LUTHN_PROJECT_NAME:-luthn}"
data_dir="${LUTHN_DATA_DIR:-${XDG_DATA_HOME:-${HOME:?HOME is required}/.local/share}/luthn}"
config_dir="${LUTHN_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/luthn}"
state_dir="${LUTHN_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/luthn}"
bin_dir="${LUTHN_BIN_DIR:-$HOME/.local/bin}"
compose_file="${LUTHN_COMPOSE_FILE:-$data_dir/compose.yaml}"
config_file="${LUTHN_CONFIG_FILE:-$config_dir/luthn.env}"
state_file="${LUTHN_STATE_FILE:-$state_dir/install-state.env}"
cli_path="${LUTHN_CLI_PATH:-$bin_dir/luthn}"
token_file="${LUTHN_SERVICE_TOKEN_FILE:-$config_dir/service-token}"
operator_token_file="${LUTHN_OPERATOR_TOKEN_FILE:-$config_dir/operator-token}"
runtime_dir="${LUTHN_RUNTIME_DIR:-$data_dir/runtime}"
connector_state_dir="${LUTHN_CONNECTOR_STATE_DIR:-$state_dir/connectors}"
codex_state_file="${LUTHN_CODEX_STATE_FILE:-$connector_state_dir/codex.env}"
codex_pending_state_file="${LUTHN_CODEX_PENDING_STATE_FILE:-$connector_state_dir/codex.pending.env}"
codex_disconnect_pending_state_file="${LUTHN_CODEX_DISCONNECT_PENDING_STATE_FILE:-$connector_state_dir/codex.disconnect.pending.env}"
cli_template_version="3"
codex_connector_version="2"
mcp_schema_version="2"
distribution_ref="${LUTHN_DISTRIBUTION_REF:-main}"
source_base_url="${LUTHN_SOURCE_BASE_URL:-https://raw.githubusercontent.com/JakobSung/Luthn/${distribution_ref}}"
default_image="ghcr.io/jakobsung/luthn:main"

print_usage() {
  cat <<'USAGE'
usage: luthn <command> [options]

commands:
  install [--connect-codex]       Install Luthn and optionally configure Codex.
  version [--json]                Show installed runtime and compatibility versions.
  status                          Show services, readiness, console, and image.
  update check [--json]           Check the configured update channel without pulling.
  update [image]                  Back up, pull, migrate, restart, and verify.
  doctor [--json]                 Diagnose runtime, update, and Codex integration state.
  reset --yes                     Delete data volumes and recreate the stack.
  uninstall                      Remove services and runtime; preserve data/config.
  uninstall --purge-data --yes   Remove services, data, config, backups, and CLI.
  connect codex [--no-auto-recall]
                                   Configure Codex; recall is enabled by default.
  connection status codex        Show local and server Codex connection state.
  disconnect codex                Remove only Luthn-owned Codex configuration.
  adapter                         Upload a turn-summary JSON payload from stdin.
  mcp [--list-tools]              Run the MCP stdio server from the image.
  help                            Show this help.
USAGE
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    echo "missing required command: $1" >&2
    exit 1
  fi
}

require_docker() {
  require_command docker
  if ! docker compose version >/dev/null 2>&1; then
    echo "docker compose plugin is required" >&2
    exit 1
  fi
  if ! docker info >/dev/null 2>&1; then
    cat >&2 <<'ERROR'
Docker is installed, but the Docker daemon is not reachable.

Start Docker Desktop or OrbStack, then verify the active context with:
  docker context ls
  docker context use <context-name>
ERROR
    exit 1
  fi
}

is_immutable_image_ref() {
  image_ref="$1"
  [[ "$image_ref" =~ @sha256:[0-9a-fA-F]{64}$ \
    || "$image_ref" =~ :sha-[0-9a-fA-F]{40}$ ]]
}

is_official_image_ref() {
  [[ "$1" == ghcr.io/jakobsung/luthn:* || "$1" == ghcr.io/jakobsung/luthn@* ]]
}

image_label() {
  image="$1"
  label="$2"
  docker image inspect --format "{{ index .Config.Labels \"$label\" }}" "$image" 2>/dev/null || true
}

image_digest() {
  image="$1"
  repo_digests="$(docker image inspect --format '{{join .RepoDigests ","}}' "$image" 2>/dev/null || true)"
  printf '%s' "$repo_digests" | awk -F, '{ value=$NF; sub(/^.*@/, "", value); print value }'
}

stable_release_version() {
  version="$1"
  if [[ "$version" =~ ^v?[0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.-]+)?$ ]]; then
    printf '%s' "$version"
  fi
}

parse_mcp_schema_version() {
  local response="$1"
  python3 - "$response" <<'PY'
import json
import sys

for line in sys.argv[1].splitlines():
    try:
        payload = json.loads(line)
        server_info = payload["result"]["serverInfo"]
        version = server_info.get("schemaVersion") or server_info["version"]
    except (KeyError, TypeError, json.JSONDecodeError):
        continue
    if isinstance(version, str) and version:
        print(version)
        raise SystemExit(0)
raise SystemExit(1)
PY
}

probe_mcp_schema_version() {
  local response
  [[ -f "$compose_file" && -f "$config_file" ]] || return 1
  response="$(printf '%s\n' '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}' \
    | compose_cmd --profile tools run --rm --no-deps -T mcp 2>/dev/null)" || return 1
  parse_mcp_schema_version "$response"
}

probe_image_mcp_schema_version() {
  local image="$1"
  local response
  response="$(printf '%s\n' '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{}}' \
    | docker run --rm -i "$image" mcp 2>/dev/null)" || return 1
  parse_mcp_schema_version "$response"
}

show_version() {
  json=false
  if [[ "${1:-}" == "--json" ]]; then
    json=true
    shift
  fi
  if (( $# > 0 )); then
    echo "usage: luthn version [--json]" >&2
    return 2
  fi

  image_ref="$(read_config LUTHN_IMAGE "$default_image")"
  running_id=""
  installed_digest=""
  source_revision=""
  release_version=""
  installed_mcp_schema=""
  if command -v docker >/dev/null 2>&1 && [[ -f "$compose_file" && -f "$config_file" ]]; then
    running_id="$(image_id_for_container)"
    if [[ -n "$running_id" ]]; then
      installed_digest="$(image_digest "$running_id")"
      source_revision="$(image_label "$running_id" org.opencontainers.image.revision)"
      release_version="$(stable_release_version "$(image_label "$running_id" org.opencontainers.image.version)")"
      installed_mcp_schema="$(image_label "$running_id" io.luthn.mcp-schema.version)"
      if [[ -z "$installed_mcp_schema" ]] && command -v python3 >/dev/null 2>&1; then
        installed_mcp_schema="$(probe_mcp_schema_version 2>/dev/null || true)"
      fi
    fi
  fi

  connector_version="$codex_connector_version"
  helper="$(codex_helper_path)"
  if [[ -f "$helper" ]] && command -v python3 >/dev/null 2>&1; then
    detected_connector_version="$(python3 "$helper" version 2>/dev/null || true)"
    [[ "$detected_connector_version" =~ ^[1-9][0-9]*$ ]] && connector_version="$detected_connector_version"
  fi

  if [[ "$json" == "true" ]]; then
    require_command python3
    python3 - "$image_ref" "$installed_digest" "$source_revision" \
      "$cli_template_version" "$connector_version" "$installed_mcp_schema" \
      "$release_version" <<'PY'
import json
import sys

keys = (
    "installedImageReference",
    "imageDigest",
    "sourceRevision",
    "cliTemplateVersion",
    "connectorTemplateVersion",
    "mcpSchemaVersion",
    "stableReleaseVersion",
)
values = [value if value else None for value in sys.argv[1:]]
print(json.dumps(dict(zip(keys, values)), separators=(",", ":")))
PY
    return
  fi

  cat <<EOF
Installed image: $image_ref
Image digest: ${installed_digest:-unavailable}
Source revision: ${source_revision:-unavailable}
CLI template: $cli_template_version
Connector template: $connector_version
MCP schema: ${installed_mcp_schema:-unavailable}
Stable release: ${release_version:-unavailable}
EOF
}

read_remote_image_metadata() {
  remote_image="$1"
  remote_manifest_json="$(docker buildx imagetools inspect "$remote_image" --format '{{json .Manifest}}')" || return 1
  remote_image_json="$(docker buildx imagetools inspect "$remote_image" --format '{{json .Image}}')" || return 1
  python3 - "$remote_manifest_json" "$remote_image_json" <<'PY'
import json
import sys

manifest = json.loads(sys.argv[1])
images = json.loads(sys.argv[2])
image = images[sorted(images)[0]] if images else {}
labels = image.get("config", {}).get("Labels", {}) or {}
values = (
    manifest.get("digest", ""),
    labels.get("org.opencontainers.image.revision", ""),
    labels.get("org.opencontainers.image.version", ""),
    labels.get("io.luthn.cli-template.version", ""),
    labels.get("io.luthn.connector-template.version", ""),
    labels.get("io.luthn.mcp-schema.version", ""),
)
print("\t".join(str(value or "") for value in values))
PY
}

print_update_check_result() {
  json="$1"
  status="$2"
  channel="$3"
  current_digest="$4"
  candidate_digest="$5"
  current_revision="$6"
  candidate_revision="$7"
  message="$8"
  if [[ "$json" == "true" ]]; then
    python3 - "$status" "$channel" "$current_digest" "$candidate_digest" \
      "$current_revision" "$candidate_revision" "$message" <<'PY'
import json
import sys

keys = (
    "status",
    "channel",
    "currentDigest",
    "candidateDigest",
    "currentRevision",
    "candidateRevision",
    "message",
)
values = [sys.argv[1], sys.argv[2], *[value if value else None for value in sys.argv[3:7]], sys.argv[7]]
print(json.dumps(dict(zip(keys, values)), separators=(",", ":")))
PY
  else
    cat <<EOF
Update status: $status
Channel: $channel
Current digest: ${current_digest:-unavailable}
Candidate digest: ${candidate_digest:-unavailable}
Current revision: ${current_revision:-unavailable}
Candidate revision: ${candidate_revision:-unavailable}
$message
EOF
  fi
}

check_for_update() {
  json=false
  if [[ "${1:-}" == "--json" ]]; then
    json=true
    shift
  fi
  if (( $# > 0 )); then
    echo "usage: luthn update check [--json]" >&2
    return 2
  fi
  require_installation
  require_docker
  require_command python3

  channel="$(read_config LUTHN_IMAGE "$default_image")"
  running_id="$(image_id_for_container)"
  current_digest=""
  current_revision=""
  if [[ -n "$running_id" ]]; then
    current_digest="$(image_digest "$running_id")"
    current_revision="$(image_label "$running_id" org.opencontainers.image.revision)"
  fi

  if is_immutable_image_ref "$channel"; then
    print_update_check_result "$json" pinned "$channel" "$current_digest" "" \
      "$current_revision" "" \
      "The configured image is immutable. Select an explicit mutable channel or target to update."
    return 0
  fi
  if ! is_official_image_ref "$channel"; then
    print_update_check_result "$json" unavailable "$channel" "$current_digest" "" \
      "$current_revision" "" \
      "Automatic checks are available only for the official Luthn image channel."
    return 0
  fi

  if ! remote_metadata="$(read_remote_image_metadata "$channel")"; then
    print_update_check_result "$json" error "$channel" "$current_digest" "" \
      "$current_revision" "" \
      "The configured update channel could not be inspected. No local state was changed."
    return 1
  fi
  IFS=$'\t' read -r candidate_digest candidate_revision candidate_release \
    candidate_cli candidate_connector candidate_mcp <<<"$remote_metadata"
  status=update-available
  message="An update is available. Run 'luthn update' when you are ready."
  identities_match=false
  if [[ -n "$current_digest" && -n "$candidate_digest" ]]; then
    [[ "$current_digest" == "$candidate_digest" ]] && identities_match=true
  elif [[ -n "$current_revision" && "$current_revision" == "$candidate_revision" ]]; then
    identities_match=true
  fi
  if [[ "$identities_match" == "true" ]]; then
    status=current
    message="The installed runtime matches the configured update channel."
  fi
  print_update_check_result "$json" "$status" "$channel" "$current_digest" \
    "$candidate_digest" "$current_revision" "$candidate_revision" "$message"
}

ensure_directories() {
  umask 077
  mkdir -p "$data_dir" "$runtime_dir" "$config_dir" "$state_dir/backups" "$connector_state_dir" "$bin_dir"
  chmod 0700 "$runtime_dir" "$config_dir" "$state_dir" "$state_dir/backups" "$connector_state_dir"
}

has_codex_connector_state() {
  [[ -f "$codex_state_file" || -f "$codex_pending_state_file" ]]
}

has_codex_connector_artifact() {
  [[ -f "$codex_state_file" || -f "$codex_pending_state_file" \
    || -f "$codex_disconnect_pending_state_file" ]]
}

read_config() {
  key="$1"
  fallback="${2:-}"
  if [[ ! -f "$config_file" ]]; then
    printf '%s' "$fallback"
    return
  fi

  value="$(awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, ""); print; exit }' "$config_file")"
  printf '%s' "${value:-$fallback}"
}

set_config() {
  key="$1"
  value="$2"
  ensure_directories
  tmp_file="$(mktemp "${config_file}.XXXXXX")"
  if [[ -f "$config_file" ]]; then
    awk -F= -v key="$key" -v value="$value" '
      BEGIN { updated = 0 }
      $1 == key { print key "=" value; updated = 1; next }
      { print }
      END { if (!updated) print key "=" value }
    ' "$config_file" >"$tmp_file"
  else
    printf '%s=%s\n' "$key" "$value" >"$tmp_file"
  fi
  chmod 0600 "$tmp_file"
  mv "$tmp_file" "$config_file"
}

remove_config() {
  key="$1"
  [[ -f "$config_file" ]] || return 0
  tmp_file="$(mktemp "${config_file}.XXXXXX")"
  awk -F= -v key="$key" '$1 != key { print }' "$config_file" >"$tmp_file"
  chmod 0600 "$tmp_file"
  mv "$tmp_file" "$config_file"
}

remove_config_prefix() {
  prefix="$1"
  [[ -f "$config_file" ]] || return 0
  tmp_file="$(mktemp "${config_file}.XXXXXX")"
  awk -F= -v prefix="$prefix" 'index($1, prefix) != 1 { print }' "$config_file" >"$tmp_file"
  chmod 0600 "$tmp_file"
  mv "$tmp_file" "$config_file"
}

write_token_file() {
  token="$1"
  ensure_directories
  umask 077
  printf '%s' "$token" >"$token_file"
  chmod 0600 "$token_file"
}

write_operator_token_file() {
  token="$1"
  ensure_directories
  umask 077
  printf '%s' "$token" >"$operator_token_file"
  chmod 0600 "$operator_token_file"
}

write_initial_config() {
  image="$1"
  digest="$2"
  operator_digest="$3"
  port="${LUTHN_PORT:-8080}"
  postgres_volume="${LUTHN_POSTGRES_VOLUME:-luthn-postgres}"
  operator_volume="${LUTHN_OPERATOR_VOLUME:-luthn-operator}"
  ensure_directories
  umask 077
  cat >"$config_file" <<EOF
LUTHN_IMAGE=$image
LUTHN_PORT=$port
LUTHN_ENVIRONMENT=Development
LUTHN_BASE_URL=http://127.0.0.1:$port
LUTHN_POSTGRES_VOLUME=$postgres_volume
LUTHN_OPERATOR_VOLUME=$operator_volume
LUTHN_SERVICE_TOKEN_FILE=$token_file
LUTHN_OPERATOR_TOKEN_FILE=$operator_token_file
LUTHN_DOCKER_CONNECTION_STRING=Host=postgres;Port=5432;Database=luthn;Username=luthn
POSTGRES_DB=luthn
POSTGRES_USER=luthn
POSTGRES_HOST_AUTH_METHOD=trust
Luthn__Classification__Provider=mock
Luthn__Auth__RequireServiceToken=true
Luthn__Auth__Tokens__0__Name=local-agent
Luthn__Auth__Tokens__0__Sha256Digest=$digest
Luthn__Auth__Tokens__0__Scopes__0=agent.read
Luthn__Auth__Tokens__0__Scopes__1=agent.write.summary
Luthn__Auth__Tokens__0__Scopes__2=memory.write
Luthn__Auth__Tokens__0__Scopes__3=memory.read
Luthn__Auth__Tokens__0__Scopes__4=classification.preview
Luthn__Auth__Tokens__0__Scopes__5=agent.connection.read
Luthn__Auth__Tokens__0__Scopes__6=agent.connection.write
Luthn__Auth__Tokens__0__Scopes__7=access.request
Luthn__Auth__Tokens__1__Name=local-operator
Luthn__Auth__Tokens__1__Sha256Digest=$operator_digest
Luthn__Auth__Tokens__1__Scopes__0=access.decide
EOF
  chmod 0600 "$config_file"
}

generate_token() {
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -hex 24
  else
    od -An -N 24 -tx1 /dev/urandom | tr -d ' \n'
  fi
}

compute_token_digest() {
  token="$1"
  image="$2"
  local digest
  if ! digest="$(printf '%s' "$token" | docker run --rm -i "$image" token-digest --stdin)"; then
    echo "operator token digest generation failed" >&2
    return 1
  fi
  if [[ ! "$digest" =~ ^sha256:[0-9a-f]{64}$ ]]; then
    echo "operator token digest output was invalid" >&2
    return 1
  fi
  printf '%s' "$digest"
}

operator_credential_slot_available() {
  image="$1"
  [[ -f "$config_file" ]] || return 0
  if ! awk -F= '$1 ~ /^Luthn__Auth__Tokens__1__/ { found = 1 } END { exit !found }' "$config_file"; then
    return 0
  fi

  operator_token_file="$(read_config LUTHN_OPERATOR_TOKEN_FILE "$operator_token_file")"
  if [[ "$(read_config Luthn__Auth__Tokens__1__Name)" != "local-operator" \
    || ! -f "$operator_token_file" ]]; then
    echo "token slot 1 is occupied and cannot be used for the local operator credential" >&2
    return 1
  fi
  operator_token="$(cat "$operator_token_file")"
  if ! operator_digest="$(compute_token_digest "$operator_token" "$image")"; then
    return 1
  fi
  if [[ "$(read_config Luthn__Auth__Tokens__1__Sha256Digest)" != "$operator_digest" ]]; then
    echo "token slot 1 is occupied and cannot be used for the local operator credential" >&2
    return 1
  fi
}

ensure_operator_credential() {
  image="$1"
  operator_credential_slot_available "$image" || return 1
  operator_token_file="$(read_config LUTHN_OPERATOR_TOKEN_FILE "$operator_token_file")"
  if [[ -f "$operator_token_file" ]]; then
    operator_token="$(cat "$operator_token_file")"
    operator_token_exists=true
  else
    operator_token="$(generate_token)"
    operator_token_exists=false
  fi
  if ! operator_digest="$(compute_token_digest "$operator_token" "$image")"; then
    return 1
  fi
  if [[ "$operator_token_exists" != "true" ]]; then
    write_operator_token_file "$operator_token"
  fi
  set_config LUTHN_OPERATOR_TOKEN_FILE "$operator_token_file"
  operator_prefix="Luthn__Auth__Tokens__1__"
  remove_config_prefix "$operator_prefix"
  set_config "${operator_prefix}Name" local-operator
  set_config "${operator_prefix}Sha256Digest" "$operator_digest"
  set_config "${operator_prefix}Scopes__0" access.decide
}

ensure_config_value() {
  key="$1"
  value="$2"
  if [[ -z "$(read_config "$key")" ]]; then
    set_config "$key" "$value"
  fi
}

pull_image() {
  image="$1"
  if [[ "${LUTHN_SKIP_PULL:-false}" == "true" ]]; then
    docker image inspect "$image" >/dev/null
  else
    docker pull "$image"
  fi
}

runtime_source_for_image() {
  image="$1"
  revision="${2:-}"
  if [[ "$image" == ghcr.io/jakobsung/luthn:* && "$revision" =~ ^[0-9a-f]{40}$ ]]; then
    printf 'https://raw.githubusercontent.com/JakobSung/Luthn/%s' "$revision"
  elif [[ "$image" =~ ^ghcr\.io/jakobsung/luthn:sha-([0-9a-f]{40})$ ]]; then
    printf 'https://raw.githubusercontent.com/JakobSung/Luthn/%s' "${BASH_REMATCH[1]}"
  else
    printf '%s' "$source_base_url"
  fi
}

download_runtime() {
  runtime_source="${1:-$source_base_url}"
  require_command curl
  ensure_directories

  compose_tmp="$(mktemp "${compose_file}.XXXXXX")"
  cli_tmp="$(mktemp "${cli_path}.XXXXXX")"
  connector_tmp="$(mktemp "${runtime_dir}/luthn-codex-connector.py.XXXXXX")"
  if ! curl -fsSL "$runtime_source/deploy/compose.yaml" -o "$compose_tmp" \
    || ! curl -fsSL "$runtime_source/scripts/luthn" -o "$cli_tmp" \
    || ! bash -n "$cli_tmp"; then
    rm -f "$compose_tmp" "$cli_tmp" "$connector_tmp"
    return 1
  fi

  connector_available=true
  if ! curl -fsSL "$runtime_source/scripts/luthn-codex-connector.py" -o "$connector_tmp"; then
    connector_available=false
    rm -f "$connector_tmp"
    if grep -q 'luthn-codex-connector.py' "$cli_tmp"; then
      rm -f "$compose_tmp" "$cli_tmp"
      return 1
    fi
    if has_codex_connector_artifact; then
      rm -f "$compose_tmp" "$cli_tmp"
      echo "The target runtime predates Codex connector support. Run 'luthn disconnect codex' before updating or rolling back." >&2
      return 1
    fi
  elif ! grep -q '^#!/usr/bin/env python3' "$connector_tmp" \
    || ! grep -q '^CONNECTOR_TEMPLATE_VERSION = "[1-9][0-9]*"$' "$connector_tmp"; then
    rm -f "$compose_tmp" "$cli_tmp" "$connector_tmp"
    return 1
  fi

  if ! install_runtime_file "$compose_tmp" "$compose_file" 0644 \
    || ! install_runtime_file "$cli_tmp" "$cli_path" 0755; then
    rm -f "$compose_tmp" "$cli_tmp" "$connector_tmp"
    return 1
  fi

  if [[ "$connector_available" == "true" ]]; then
    if ! install_runtime_file \
      "$connector_tmp" "$runtime_dir/luthn-codex-connector.py" 0700; then
      rm -f "$connector_tmp"
      return 1
    fi
  else
    rm -f "$runtime_dir/luthn-codex-connector.py"
  fi
}

install_runtime_file() {
  staged_file="$1"
  destination="$2"
  mode="$3"
  if [[ -f "$destination" ]] && cmp -s "$staged_file" "$destination"; then
    rm -f "$staged_file"
    return 0
  fi
  chmod "$mode" "$staged_file" && mv "$staged_file" "$destination"
}

ensure_connector_scopes() {
  connector_scopes_changed=false
  local check_only="${1:-false}"
  if ! ensure_directories; then
    return 1
  fi

  local read_present=false
  local write_present=false
  local access_request_present=false
  local wildcard_present=false
  local scope_value
  local scope_index
  local empty_indices=()
  for scope_index in {0..15}; do
    if ! scope_value="$(read_config "Luthn__Auth__Tokens__0__Scopes__${scope_index}")"; then
      return 1
    fi
    case "$scope_value" in
      '*') wildcard_present=true ;;
      agent.connection.read) read_present=true ;;
      agent.connection.write) write_present=true ;;
      access.request) access_request_present=true ;;
      '') empty_indices+=("$scope_index") ;;
    esac
  done

  if [[ "$wildcard_present" == "true" \
    || ( "$read_present" == "true" && "$write_present" == "true" && "$access_request_present" == "true" ) ]]; then
    return 0
  fi

  local required_slots=0
  [[ "$read_present" == "true" ]] || required_slots=$((required_slots + 1))
  [[ "$write_present" == "true" ]] || required_slots=$((required_slots + 1))
  [[ "$access_request_present" == "true" ]] || required_slots=$((required_slots + 1))
  if (( ${#empty_indices[@]} < required_slots )); then
    echo "No free service-token scope slots are available for the connector." >&2
    return 1
  fi
  if [[ "$check_only" == "--check-only" ]]; then
    return 0
  fi

  local key1=""
  local value1=""
  local key2=""
  local value2=""
  local key3=""
  local value3=""
  local next_slot=0
  if [[ "$read_present" != "true" ]]; then
    key1="Luthn__Auth__Tokens__0__Scopes__${empty_indices[$next_slot]}"
    value1="agent.connection.read"
    next_slot=$((next_slot + 1))
  fi
  if [[ "$write_present" != "true" ]]; then
    if [[ -z "$key1" ]]; then
      key1="Luthn__Auth__Tokens__0__Scopes__${empty_indices[$next_slot]}"
      value1="agent.connection.write"
    else
      key2="Luthn__Auth__Tokens__0__Scopes__${empty_indices[$next_slot]}"
      value2="agent.connection.write"
    fi
    next_slot=$((next_slot + 1))
  fi
  if [[ "$access_request_present" != "true" ]]; then
    if [[ -z "$key1" ]]; then
      key1="Luthn__Auth__Tokens__0__Scopes__${empty_indices[$next_slot]}"
      value1="access.request"
    elif [[ -z "$key2" ]]; then
      key2="Luthn__Auth__Tokens__0__Scopes__${empty_indices[$next_slot]}"
      value2="access.request"
    else
      key3="Luthn__Auth__Tokens__0__Scopes__${empty_indices[$next_slot]}"
      value3="access.request"
    fi
  fi

  local input_file="$config_file"
  [[ -f "$input_file" ]] || input_file=/dev/null
  local config_tmp
  if ! config_tmp="$(mktemp "${config_file}.connector-scopes.XXXXXX")"; then
    return 1
  fi
  if ! awk -F= -v key1="$key1" -v value1="$value1" -v key2="$key2" -v value2="$value2" -v key3="$key3" -v value3="$value3" '
    BEGIN { updated1 = 0; updated2 = 0; updated3 = 0 }
    key1 != "" && $1 == key1 { print key1 "=" value1; updated1 = 1; next }
    key2 != "" && $1 == key2 { print key2 "=" value2; updated2 = 1; next }
    key3 != "" && $1 == key3 { print key3 "=" value3; updated3 = 1; next }
    { print }
    END {
      if (key1 != "" && !updated1) print key1 "=" value1
      if (key2 != "" && !updated2) print key2 "=" value2
      if (key3 != "" && !updated3) print key3 "=" value3
    }
  ' "$input_file" >"$config_tmp"; then
    rm -f "$config_tmp"
    return 1
  fi
  if ! chmod 0600 "$config_tmp" || ! mv "$config_tmp" "$config_file"; then
    rm -f "$config_tmp"
    return 1
  fi
  connector_scopes_changed=true
}

ensure_access_request_scope() {
  connector_scopes_changed=false
  local index key value
  for index in $(seq 0 15); do
    key="Luthn__Auth__Tokens__0__Scopes__${index}"
    value="$(read_config "$key")"
    if [[ "$value" == "*" || "$value" == "access.request" ]]; then
      return 0
    fi
  done

  for index in $(seq 0 15); do
    key="Luthn__Auth__Tokens__0__Scopes__${index}"
    if [[ -z "$(read_config "$key")" ]]; then
      set_config "$key" access.request
      connector_scopes_changed=true
      return 0
    fi
  done

  echo "No free service-token scope slot is available for access.request." >&2
  return 1
}

require_installation() {
  if [[ ! -f "$compose_file" || ! -f "$config_file" ]]; then
    echo "Luthn is not installed. Run: luthn install" >&2
    exit 1
  fi
}

compose_cmd() {
  docker compose --project-name "$project_name" --env-file "$config_file" -f "$compose_file" "$@"
}

stop_api_fail_closed() {
  if compose_cmd stop api >/dev/null 2>&1; then
    return 0
  fi

  local api_container_id
  if ! api_container_id="$(compose_cmd ps -q api 2>/dev/null)"; then
    return 1
  fi
  if [[ -z "$api_container_id" ]]; then
    return 0
  fi

  docker stop "$api_container_id" >/dev/null 2>&1 \
    || docker kill "$api_container_id" >/dev/null 2>&1
}

wait_for_postgres() {
  attempts=60
  while (( attempts > 0 )); do
    if compose_cmd exec -T postgres pg_isready \
      -U "$(read_config POSTGRES_USER luthn)" \
      -d "$(read_config POSTGRES_DB luthn)" >/dev/null 2>&1; then
      return 0
    fi
    attempts=$((attempts - 1))
    sleep 2
  done
  echo "PostgreSQL did not become ready." >&2
  compose_cmd ps postgres >&2 || true
  return 1
}

wait_for_api() {
  require_command curl
  base_url="$(read_config LUTHN_BASE_URL http://127.0.0.1:8080)"
  attempts=60
  while (( attempts > 0 )); do
    if curl -fsS "$base_url/healthz" >/dev/null 2>&1 \
      && curl -fsS "$base_url/readyz" >/dev/null 2>&1; then
      return 0
    fi
    attempts=$((attempts - 1))
    sleep 2
  done
  echo "Luthn did not pass health and readiness checks." >&2
  compose_cmd ps >&2 || true
  compose_cmd logs --tail 100 api migrate >&2 || true
  return 1
}

image_id_for_container() {
  container_id="$(compose_cmd ps -q api 2>/dev/null || true)"
  if [[ -n "$container_id" ]]; then
    docker inspect --format '{{.Image}}' "$container_id" 2>/dev/null || true
  fi
}

record_state() {
  status="$1"
  image_ref="$2"
  image_id="$3"
  previous_image_id="${4:-}"
  backup_path="${5:-}"
  ensure_directories
  umask 077
  cat >"$state_file" <<EOF
STATUS=$status
IMAGE_REF=$image_ref
IMAGE_ID=$image_id
PREVIOUS_IMAGE_ID=$previous_image_id
BACKUP_PATH=$backup_path
UPDATED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF
  chmod 0600 "$state_file"
}

start_stack() {
  seed_demo="$1"
  compose_cmd up -d postgres
  wait_for_postgres
  compose_cmd run --rm --no-deps migrate
  compose_cmd up -d api
  wait_for_api
  if [[ "$seed_demo" == "true" ]]; then
    compose_cmd --profile tools run --rm --no-deps seed
  fi
}

install_luthn() {
  connect_after_install=false
  while (( $# > 0 )); do
    case "$1" in
      --connect-codex) connect_after_install=true ;;
      *) echo "usage: luthn install [--connect-codex]" >&2; return 2 ;;
    esac
    shift
  done

  require_docker
  require_command curl

  if [[ -f "$config_file" ]] && has_codex_connector_state \
    && ! ensure_connector_scopes --check-only; then
    echo "Install stopped because the active Codex connector scopes could not be configured." >&2
    return 1
  fi

  image="$(read_config LUTHN_IMAGE "${LUTHN_IMAGE:-$default_image}")"
  echo "Pulling $image..."
  pull_image "$image"
  if ! operator_credential_slot_available "$image"; then
    echo "Install stopped because the local operator credential could not be configured." >&2
    return 1
  fi
  image_revision="$(docker image inspect --format '{{ index .Config.Labels "org.opencontainers.image.revision" }}' "$image" 2>/dev/null || true)"
  download_runtime "$(runtime_source_for_image "$image" "$image_revision")"

  if [[ ! -f "$config_file" ]]; then
    token="$(generate_token)"
    digest="$(printf '%s' "$token" | docker run --rm -i "$image" token-digest --stdin)"
    operator_token="$(generate_token)"
    if ! operator_digest="$(compute_token_digest "$operator_token" "$image")"; then
      echo "Install stopped because the local operator credential could not be configured." >&2
      return 1
    fi
    write_token_file "$token"
    write_operator_token_file "$operator_token"
    write_initial_config "$image" "$digest" "$operator_digest"
  else
    ensure_config_value LUTHN_IMAGE "$image"
    ensure_config_value LUTHN_PORT "${LUTHN_PORT:-8080}"
    ensure_config_value LUTHN_ENVIRONMENT Development
    ensure_config_value LUTHN_BASE_URL "http://127.0.0.1:$(read_config LUTHN_PORT 8080)"
    ensure_config_value LUTHN_POSTGRES_VOLUME "${LUTHN_POSTGRES_VOLUME:-luthn-postgres}"
    ensure_config_value LUTHN_OPERATOR_VOLUME "${LUTHN_OPERATOR_VOLUME:-luthn-operator}"
    token_file="$(read_config LUTHN_SERVICE_TOKEN_FILE "$token_file")"
    token=""
    if [[ -f "$token_file" ]]; then
      token="$(cat "$token_file")"
    elif [[ -n "$(read_config LUTHN_SERVICE_VALUE)" ]]; then
      token="$(read_config LUTHN_SERVICE_VALUE)"
      write_token_file "$token"
    else
      token="$(generate_token)"
      write_token_file "$token"
    fi
    set_config LUTHN_SERVICE_TOKEN_FILE "$token_file"
    remove_config LUTHN_SERVICE_VALUE
    digest="$(printf '%s' "$token" | docker run --rm -i "$image" token-digest --stdin)"
    set_config Luthn__Auth__Tokens__0__Sha256Digest "$digest"
    ensure_config_value LUTHN_DOCKER_CONNECTION_STRING "Host=postgres;Port=5432;Database=luthn;Username=luthn"
    ensure_config_value POSTGRES_DB luthn
    ensure_config_value POSTGRES_USER luthn
    ensure_config_value POSTGRES_HOST_AUTH_METHOD trust
    ensure_config_value Luthn__Classification__Provider mock
    ensure_config_value Luthn__Auth__RequireServiceToken true
    ensure_config_value Luthn__Auth__Tokens__0__Name local-agent
    ensure_config_value Luthn__Auth__Tokens__0__Scopes__0 agent.read
    ensure_config_value Luthn__Auth__Tokens__0__Scopes__1 agent.write.summary
    ensure_config_value Luthn__Auth__Tokens__0__Scopes__2 memory.write
    ensure_config_value Luthn__Auth__Tokens__0__Scopes__3 memory.read
    ensure_config_value Luthn__Auth__Tokens__0__Scopes__4 classification.preview
  fi
  if ! ensure_operator_credential "$image"; then
    echo "Install stopped because the local operator credential could not be configured." >&2
    return 1
  fi
  if has_codex_connector_state; then
    if ! ensure_connector_scopes; then
      echo "Install stopped because the active Codex connector scopes could not be configured." >&2
      return 1
    fi
  elif ! ensure_access_request_scope; then
    echo "warning: access.request could not be added because the custom service-token scope table is full" >&2
  fi

  echo "Starting Luthn..."
  compose_cmd pull postgres
  start_stack true
  current_id="$(image_id_for_container)"
  record_state ready "$(read_config LUTHN_IMAGE "$image")" "$current_id"
  refresh_codex_connection_observation || \
    echo "warning: installed Codex connector status could not be reported" >&2

  cat <<EOF

Luthn is ready.
Console: $(read_config LUTHN_BASE_URL http://127.0.0.1:8080)/
Status:  $cli_path status
Config:  $config_file
Operator token: $operator_token_file
Agent:   $cli_path connect codex
EOF

  if [[ "$connect_after_install" == "true" ]]; then
    echo
    connect_codex
  fi
}

show_status() {
  require_installation
  require_docker
  require_command curl
  base_url="$(read_config LUTHN_BASE_URL http://127.0.0.1:8080)"
  image_ref="$(read_config LUTHN_IMAGE "$default_image")"
  image_id="$(image_id_for_container)"
  image_digest=""
  running_revision=""
  selected_id=""
  selected_revision=""
  if [[ -n "$image_id" ]]; then
    image_digest="$(docker image inspect --format '{{join .RepoDigests ", "}}' "$image_id" 2>/dev/null || true)"
    running_revision="$(docker image inspect --format '{{ index .Config.Labels "org.opencontainers.image.revision" }}' "$image_id" 2>/dev/null || true)"
  fi
  selected_id="$(docker image inspect --format '{{.Id}}' "$image_ref" 2>/dev/null || true)"
  selected_revision="$(docker image inspect --format '{{ index .Config.Labels "org.opencontainers.image.revision" }}' "$image_ref" 2>/dev/null || true)"

  echo "Luthn services:"
  compose_cmd ps
  echo
  if curl -fsS "$base_url/healthz" >/dev/null 2>&1; then
    echo "Health: ready"
  else
    echo "Health: unavailable"
  fi
  if curl -fsS "$base_url/readyz" >/dev/null 2>&1; then
    echo "Readiness: ready"
  else
    echo "Readiness: not ready"
  fi
  echo "Console: $base_url/"
  echo "Image: $image_ref"
  echo "Image ID: ${image_id:-unavailable}"
  echo "Digest: ${image_digest:-unavailable}"
  echo "Running revision: ${running_revision:-unavailable}"
  echo "Selected revision: ${selected_revision:-unavailable}"
  if [[ -n "$image_id" && -n "$selected_id" && "$image_id" != "$selected_id" ]]; then
    echo "Runtime drift: a locally selected image is not running; run 'luthn update'."
  fi
}

doctor_add_check() {
  doctor_checks+=("$1|$2|$3|$4|$5")
  if [[ "$2" == "fail" && "$3" == "true" ]]; then
    doctor_failed=true
  fi
}

show_doctor() {
  json=false
  if [[ "${1:-}" == "--json" ]]; then
    json=true
    shift
  fi
  if (( $# > 0 )); then
    echo "usage: luthn doctor [--json]" >&2
    return 2
  fi

  doctor_checks=()
  doctor_failed=false
  if command -v docker >/dev/null 2>&1; then
    doctor_add_check docker pass true "Docker CLI is available." ""
    if docker compose version >/dev/null 2>&1; then
      doctor_add_check compose pass true "Docker Compose is available." ""
    else
      doctor_add_check compose fail true "Docker Compose is unavailable." "Install the Docker Compose plugin."
    fi
    if docker info >/dev/null 2>&1; then
      doctor_add_check docker-daemon pass true "Docker daemon is reachable." ""
    else
      doctor_add_check docker-daemon fail true "Docker daemon is not reachable." "Start Docker and verify the active Docker context."
    fi
  else
    doctor_add_check docker fail true "Docker CLI is unavailable." "Install Docker Desktop or Docker Engine."
    doctor_add_check compose fail true "Docker Compose could not be checked." "Install Docker with the Compose plugin."
    doctor_add_check docker-daemon fail true "Docker daemon could not be checked." "Install and start Docker."
  fi

  if [[ -f "$compose_file" && -f "$config_file" && -f "$cli_path" ]]; then
    doctor_add_check installation pass true "Installed runtime files are present." ""
  else
    doctor_add_check installation fail true "Installed runtime files are incomplete." "Run 'luthn install' to repair the installation."
  fi

  base_url="$(read_config LUTHN_BASE_URL http://127.0.0.1:8080)"
  readiness_body=""
  readiness_code=""
  if command -v curl >/dev/null 2>&1 && curl -fsS "$base_url/healthz" >/dev/null 2>&1; then
    doctor_add_check api-health pass true "API health check passed." ""
  else
    doctor_add_check api-health fail true "API health check failed." "Run 'luthn status' and inspect API logs."
  fi
  readiness_response=""
  if command -v curl >/dev/null 2>&1 \
    && readiness_response="$(curl -sS -w $'\n%{http_code}' "$base_url/readyz" 2>/dev/null)"; then
    readiness_code="${readiness_response##*$'\n'}"
    readiness_body="${readiness_response%$'\n'*}"
  fi
  if [[ "$readiness_code" =~ ^2[0-9][0-9]$ ]]; then
    doctor_add_check api-readiness pass true "API readiness check passed." ""
    doctor_add_check migrations pass true "Database migrations are current." ""
  elif [[ "$readiness_body" == *"pending migrations"* ]]; then
    doctor_add_check api-readiness fail true "API is not ready because migrations are pending." "Run 'luthn update' to apply the target migrations."
    doctor_add_check migrations fail true "Database has pending migrations." "Run 'luthn update'."
  else
    doctor_add_check api-readiness fail true "API readiness check failed." "Run 'luthn status' and inspect API and migration logs."
    doctor_add_check migrations warn false "Migration state could not be confirmed while readiness is unavailable." "Restore API readiness, then run 'luthn doctor' again."
  fi

  running_id=""
  selected_id=""
  if command -v docker >/dev/null 2>&1 && [[ -f "$compose_file" && -f "$config_file" ]]; then
    running_id="$(image_id_for_container)"
    selected_ref="$(read_config LUTHN_IMAGE "$default_image")"
    selected_id="$(docker image inspect --format '{{.Id}}' "$selected_ref" 2>/dev/null || true)"
  fi
  if [[ -n "$running_id" && -n "$selected_id" && "$running_id" == "$selected_id" ]]; then
    doctor_add_check runtime-drift pass true "The selected image is running." ""
  elif [[ -n "$running_id" && -n "$selected_id" ]]; then
    doctor_add_check runtime-drift fail true "The selected image is not running." "Run 'luthn update' to reconcile runtime drift."
  else
    doctor_add_check runtime-drift warn false "Runtime image identity could not be confirmed." "Start Luthn and run the doctor again."
  fi

  update_json=""
  update_status="error"
  if command -v python3 >/dev/null 2>&1 && update_json="$(check_for_update --json 2>/dev/null)"; then
    update_status="$(python3 -c 'import json,sys; print(json.load(sys.stdin).get("status", "error"))' <<<"$update_json" 2>/dev/null || printf error)"
    case "$update_status" in
      current) doctor_add_check update-check pass false "The configured channel is current." "" ;;
      update-available) doctor_add_check update-check warn false "An update is available." "Run 'luthn update' when ready." ;;
      pinned) doctor_add_check update-check warn false "The installation is pinned to an immutable image." "Choose an explicit target to update." ;;
      unavailable) doctor_add_check update-check warn false "Automatic update checks are unavailable for this image channel." "Check the custom registry manually." ;;
      *) doctor_add_check update-check warn false "Update status could not be determined." "Run 'luthn update check' for details." ;;
    esac
  else
    doctor_add_check update-check warn false "The configured update channel could not be checked." "Run 'luthn update check' after network access is restored."
  fi

  if has_codex_connector_state; then
    helper="$(codex_helper_path)"
    if [[ -f "$helper" ]]; then
      doctor_add_check codex-helper pass true "Codex connector helper is present." ""
    else
      doctor_add_check codex-helper fail true "Codex connector helper is missing." "Run 'luthn connect codex'."
    fi
    hooks_file="$(codex_state_value HOOKS_FILE)"
    [[ -n "$hooks_file" ]] || hooks_file="$(codex_hooks_path)"
    if [[ -f "$helper" ]] && python3 "$helper" hooks check --path "$hooks_file" --command "$(codex_hook_command)" >/dev/null 2>&1; then
      doctor_add_check codex-hook pass true "Codex Stop hook is configured." ""
    else
      doctor_add_check codex-hook fail true "Codex Stop hook is missing or changed." "Run 'luthn connect codex'."
    fi
    if [[ "$(codex_state_value AUTO_RECALL)" == "true" ]]; then
      instructions_file="$(codex_state_value INSTRUCTIONS_FILE)"
      [[ -n "$instructions_file" ]] || instructions_file="$(codex_instructions_path)"
      if [[ -f "$helper" ]] && python3 "$helper" instructions check --path "$instructions_file" >/dev/null 2>&1; then
        doctor_add_check auto-recall pass true "Codex auto-recall instructions are configured." ""
      else
        doctor_add_check auto-recall fail true "Codex auto-recall instructions are missing or changed." "Run 'luthn connect codex'."
      fi
    else
      doctor_add_check auto-recall pass false "Codex auto-recall is intentionally disabled." ""
    fi
    if command -v codex >/dev/null 2>&1 && codex_mcp_registration_status; then
      doctor_add_check codex-mcp pass true "Codex MCP registration matches Luthn." ""
    else
      doctor_add_check codex-mcp fail true "Codex MCP registration is missing or changed." "Run 'luthn connect codex'."
    fi
  else
    doctor_add_check codex-helper warn false "Codex is not connected to Luthn." "Run 'luthn connect codex' when this host should use Luthn."
  fi

  overall=ready
  [[ "$doctor_failed" == "true" ]] && overall=failed
  if [[ "$json" == "true" ]]; then
    require_command python3
    python3 - "$overall" "${doctor_checks[@]}" <<'PY'
import json
import sys

checks = []
for encoded in sys.argv[2:]:
    name, status, required, message, remediation = encoded.split("|", 4)
    checks.append({
        "name": name,
        "status": status,
        "required": required == "true",
        "message": message,
        "remediation": remediation or None,
    })
print(json.dumps({"status": sys.argv[1], "checks": checks}, separators=(",", ":")))
PY
  else
    echo "Luthn doctor: $overall"
    for encoded in "${doctor_checks[@]}"; do
      IFS='|' read -r name status required message remediation <<<"$encoded"
      printf '%-18s %-5s %s\n' "$name" "$status" "$message"
      [[ -n "$remediation" ]] && printf '  remediation: %s\n' "$remediation"
    done
  fi
  [[ "$doctor_failed" != "true" ]]
}

codex_helper_path() {
  if [[ -n "${LUTHN_CODEX_CONNECTOR_HELPER:-}" ]]; then
    printf '%s' "$LUTHN_CODEX_CONNECTOR_HELPER"
    return
  fi
  if [[ -f "$runtime_dir/luthn-codex-connector.py" ]]; then
    printf '%s' "$runtime_dir/luthn-codex-connector.py"
    return
  fi
  source_helper="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/luthn-codex-connector.py"
  printf '%s' "$source_helper"
}

read_codex_helper_digests() {
  digest_helper="$1"
  codex_helper_digest=""
  codex_template_digest=""
  helper_digest_supported=false
  template_digest_supported=false
  if codex_helper_digest="$(python3 "$digest_helper" helper-digest 2>/dev/null)"; then
    helper_digest_supported=true
  fi
  if codex_template_digest="$(python3 "$digest_helper" template-digest 2>/dev/null)"; then
    template_digest_supported=true
  fi
  if [[ "$helper_digest_supported" == "true" && "$template_digest_supported" == "true" ]]; then
    [[ "$codex_helper_digest" =~ ^[0-9a-f]{64}$ \
      && "$codex_template_digest" =~ ^[0-9a-f]{64}$ ]]
    return
  fi
  if [[ "$helper_digest_supported" == "false" && "$template_digest_supported" == "false" ]]; then
    return 2
  fi
  return 1
}

ensure_codex_connector_helper() {
  helper="$(codex_helper_path)"
  if [[ -f "$helper" ]]; then
    current_version="$(python3 "$helper" version 2>/dev/null || true)"
    expected_helper_digest="$(codex_state_value HELPER_DIGEST)"
    expected_template_digest="$(codex_state_value TEMPLATE_DIGEST)"
    digest_status=0
    read_codex_helper_digests "$helper" || digest_status=$?
    if [[ "$current_version" == "$codex_connector_version" && "$digest_status" -eq 0 \
      && ( -z "$expected_helper_digest" || "$codex_helper_digest" == "$expected_helper_digest" ) \
      && ( -z "$expected_template_digest" || "$codex_template_digest" == "$expected_template_digest" ) ]]; then
      return 0
    fi
    if [[ "$current_version" == "$codex_connector_version" && "$digest_status" -eq 2 \
      && -z "$expected_helper_digest" && -z "$expected_template_digest" ]]; then
      return 0
    fi
  fi
  image="$(read_config LUTHN_IMAGE "$default_image")"
  image_revision="$(docker image inspect --format '{{ index .Config.Labels "org.opencontainers.image.revision" }}' "$image" 2>/dev/null || true)"
  runtime_source="$(runtime_source_for_image "$image" "$image_revision")"
  helper_parent="$(dirname "$helper")"
  mkdir -p "$helper_parent" || return 1
  helper_tmp="$(mktemp "${helper}.XXXXXX")" || return 1
  if ! curl -fsSL "$runtime_source/scripts/luthn-codex-connector.py" -o "$helper_tmp" \
    || ! grep -q '^#!/usr/bin/env python3' "$helper_tmp" \
    || ! grep -q '^CONNECTOR_TEMPLATE_VERSION = "[1-9][0-9]*"$' "$helper_tmp"; then
    rm -f "$helper_tmp"
    return 1
  fi
  helper_tmp_version="$(python3 "$helper_tmp" version 2>/dev/null)" || {
    rm -f "$helper_tmp"
    return 1
  }
  if ! [[ "$helper_tmp_version" =~ ^[1-9][0-9]*$ ]]; then
    rm -f "$helper_tmp"
    return 1
  fi
  digest_status=0
  read_codex_helper_digests "$helper_tmp" || digest_status=$?
  if [[ "$digest_status" -eq 1 ]] \
    || ! install_runtime_file "$helper_tmp" "$helper" 0700; then
    rm -f "$helper_tmp"
    return 1
  fi
}

reconcile_codex_managed_configuration() {
  has_codex_connector_state || return 0
  helper="$(codex_helper_path)"
  [[ -f "$helper" ]] || return 1
  hooks_file="$(codex_state_value HOOKS_FILE)"
  [[ -n "$hooks_file" ]] || hooks_file="$(codex_hooks_path)"
  instructions_file="$(codex_state_value INSTRUCTIONS_FILE)"
  [[ -n "$instructions_file" ]] || instructions_file="$(codex_instructions_path)"
  hook_command="$(codex_hook_command)"
  auto_recall="$(codex_state_value AUTO_RECALL)"

  python3 "$helper" hooks install --path "$hooks_file" --command "$hook_command" || return 1
  if [[ "$auto_recall" == "true" ]]; then
    python3 "$helper" instructions install --path "$instructions_file" || return 1
  else
    python3 "$helper" instructions remove --path "$instructions_file" || return 1
  fi

  mcp_probe="$(compose_cmd --profile tools run --rm --no-deps -T mcp mcp --list-tools 2>&1)" \
    || return 1
  printf '%s\n' "$mcp_probe" | grep -q '^get_context_pack$' || return 1

  target_connector_version="$(python3 "$helper" version 2>/dev/null)" || return 1
  [[ "$target_connector_version" =~ ^[1-9][0-9]*$ ]] || return 1
  digest_status=0
  read_codex_helper_digests "$helper" || digest_status=$?
  [[ "$digest_status" -ne 1 ]] || return 1
  target_helper_digest="$codex_helper_digest"
  target_template_digest="$codex_template_digest"
  digest_mode=modern
  [[ "$digest_status" -eq 2 ]] && digest_mode=legacy
  installed_connector_version="$(codex_state_value CONNECTOR_VERSION)"
  installed_helper_digest="$(codex_state_value HELPER_DIGEST)"
  installed_template_digest="$(codex_state_value TEMPLATE_DIGEST)"
  if [[ "$installed_connector_version" != "$target_connector_version" \
    || "$installed_helper_digest" != "$target_helper_digest" \
    || "$installed_template_digest" != "$target_template_digest" ]]; then
    mcp_changed="$(codex_state_value MCP_CHANGED)"
    [[ -n "$mcp_changed" ]] || mcp_changed=false
    record_codex_connector_state \
      "$hooks_file" "$codex_state_file" configured "$mcp_changed" \
      "$auto_recall" "$instructions_file" "$target_connector_version" \
      "$target_helper_digest" "$target_template_digest" "$digest_mode"
  fi
}

codex_hooks_path() {
  printf '%s' "${LUTHN_CODEX_HOOKS_FILE:-${CODEX_HOME:-$HOME/.codex}/hooks.json}"
}

codex_instructions_path() {
  printf '%s' "${LUTHN_CODEX_INSTRUCTIONS_FILE:-${CODEX_HOME:-$HOME/.codex}/AGENTS.md}"
}

codex_hook_command() {
  printf '%q codex-hook' "$cli_path"
}

codex_mcp_registration_status() {
  if ! mcp_output="$(codex mcp get luthn 2>/dev/null)"; then
    return 1
  fi

  registered_command="$(printf '%s\n' "$mcp_output" | sed -n 's/^  command: //p' | head -n 1)"
  registered_args="$(printf '%s\n' "$mcp_output" | sed -n 's/^  args: //p' | head -n 1)"
  if [[ "$registered_command" == "$cli_path" && "$registered_args" == "mcp" ]]; then
    return 0
  fi
  return 2
}

record_codex_connector_state() {
  hooks_file="$1"
  destination="${2:-$codex_state_file}"
  setup_state="${3:-configured}"
  mcp_changed="${4:-false}"
  auto_recall="${5:-false}"
  instructions_file="${6:-$(codex_instructions_path)}"
  connector_version="${7:-$codex_connector_version}"
  helper_digest="${8:-}"
  template_digest="${9:-}"
  digest_mode="${10:-auto}"
  helper="$(codex_helper_path)"
  if [[ "$digest_mode" == "auto" ]]; then
    digest_status=0
    read_codex_helper_digests "$helper" || digest_status=$?
    [[ "$digest_status" -ne 1 ]] || return 1
    if [[ "$digest_status" -eq 0 ]]; then
      helper_digest="$codex_helper_digest"
      template_digest="$codex_template_digest"
      digest_mode=modern
    else
      digest_mode=legacy
    fi
  fi
  digest_lines=""
  if [[ "$digest_mode" == "modern" ]]; then
    [[ "$helper_digest" =~ ^[0-9a-f]{64}$ ]] || return 1
    [[ "$template_digest" =~ ^[0-9a-f]{64}$ ]] || return 1
    digest_lines="$(printf 'HELPER_DIGEST=%s\nTEMPLATE_DIGEST=%s' "$helper_digest" "$template_digest")"
  elif [[ "$digest_mode" != "legacy" ]]; then
    return 1
  fi
  ensure_directories || return 1
  state_tmp="$(mktemp "${destination}.XXXXXX")" || return 1
  if ! cat >"$state_tmp" <<EOF
AGENT_ID=codex
AGENT_NAME=Codex
INTEGRATION_KIND=host-hook-mcp
CONNECTOR_VERSION=$connector_version
$digest_lines
CONFIGURATION_OWNER=luthn
CHANNELS=automatic-ingestion,mcp
HOOKS_FILE=$hooks_file
INSTRUCTIONS_FILE=$instructions_file
AUTO_RECALL=$auto_recall
MCP_NAME=luthn
SETUP_STATE=$setup_state
MCP_CHANGED=$mcp_changed
UPDATED_AT=$(date -u +%Y-%m-%dT%H:%M:%SZ)
EOF
  then
    rm -f "$state_tmp"
    return 1
  fi
  if ! chmod 0600 "$state_tmp" || ! mv "$state_tmp" "$destination"; then
    rm -f "$state_tmp"
    return 1
  fi
}

codex_state_value() {
  key="$1"
  connector_state="$codex_state_file"
  [[ -f "$connector_state" ]] || connector_state="$codex_pending_state_file"
  [[ -f "$connector_state" ]] || connector_state="$codex_disconnect_pending_state_file"
  [[ -f "$connector_state" ]] || return 0
  awk -F= -v key="$key" '$1 == key { sub(/^[^=]*=/, ""); print; exit }' "$connector_state"
}

report_codex_observation() {
  helper="$(codex_helper_path)"
  [[ -f "$helper" && -f "$config_file" ]] || return 1
  service_token_file="$(read_config LUTHN_SERVICE_TOKEN_FILE "$token_file")"
  base_url="$(read_config LUTHN_BASE_URL http://127.0.0.1:8080)"
  [[ -f "$service_token_file" ]] || return 1

  report_args=(
    "$helper" report
    --base-url "$base_url"
    --token-file "$service_token_file"
    --connector-version "$codex_connector_version"
  )
  while (( $# > 0 )); do
    report_args+=(--channel "$1")
    shift
  done
  python3 "${report_args[@]}"
}

report_pending_codex_disconnect() {
  [[ -f "$codex_disconnect_pending_state_file" ]] || return 0

  mcp_changed="$(awk -F= '$1 == "MCP_CHANGED" { print $2; exit }' "$codex_disconnect_pending_state_file")"
  if [[ "$mcp_changed" == "true" ]]; then
    if ! report_codex_observation \
      "automatic-ingestion:false:Unknown:Unknown:" \
      "mcp:true:Failed:Unknown:configuration.changed" >/dev/null; then
      return 1
    fi
  else
    if ! report_codex_observation \
      "automatic-ingestion:false:Unknown:Unknown:" \
      "mcp:false:Unknown:Unknown:" >/dev/null; then
      return 1
    fi
  fi
  rm -f "$codex_disconnect_pending_state_file"
}

refresh_codex_connection_observation() {
  if [[ -f "$codex_disconnect_pending_state_file" ]]; then
    if has_codex_connector_state; then
      rm -f "$codex_disconnect_pending_state_file"
    else
      report_pending_codex_disconnect
      return
    fi
  fi
  [[ -f "$codex_state_file" ]] || return 0
  command -v python3 >/dev/null 2>&1 || return 1
  helper="$(codex_helper_path)"
  [[ -f "$helper" ]] || return 1

  hooks_file="$(codex_state_value HOOKS_FILE)"
  [[ -n "$hooks_file" ]] || hooks_file="$(codex_hooks_path)"
  hook_command="$(codex_hook_command)"
  if python3 "$helper" hooks check --path "$hooks_file" --command "$hook_command"; then
    automatic_spec="automatic-ingestion:true:Unknown:Unknown:"
  else
    automatic_spec="automatic-ingestion:false:Unknown:Unknown:"
  fi

  if command -v codex >/dev/null 2>&1; then
    if codex_mcp_registration_status; then
      mcp_spec="mcp:true:Verified:Unknown:"
    else
      mcp_status=$?
      if [[ "$mcp_status" -eq 2 ]]; then
        mcp_spec="mcp:true:Failed:Unknown:configuration.changed"
      else
        mcp_spec="mcp:false:Unknown:Unknown:"
      fi
    fi
  else
    mcp_spec="mcp:false:Unknown:Unknown:"
  fi

  report_codex_observation "$automatic_spec" "$mcp_spec" >/dev/null
}

restore_hooks_backup() {
  hooks_file="$1"
  backup_file="$2"
  hooks_existed="$3"
  if [[ "$hooks_existed" == "true" ]]; then
    cp -p "$backup_file" "$hooks_file"
  else
    rm -f "$hooks_file"
  fi
}

rollback_codex_registration() {
  hooks_file="$1"
  hooks_backup="$2"
  hooks_existed="$3"
  mcp_preexisting="$4"

  restore_hooks_backup "$hooks_file" "$hooks_backup" "$hooks_existed"
  if [[ "$mcp_preexisting" == "false" ]] \
    && ! codex mcp remove luthn >/dev/null 2>&1; then
    echo "Codex MCP cleanup failed. Partial connector ownership was preserved; run 'luthn disconnect codex' and retry." >&2
    return 1
  fi
  rm -f "$codex_pending_state_file"
}

restore_connector_config_backup() {
  backup_file="$1"
  restore_tmp="$(mktemp "${config_file}.restore.XXXXXX")" || return 1
  if ! cp -p "$backup_file" "$restore_tmp" || ! mv "$restore_tmp" "$config_file"; then
    rm -f "$restore_tmp"
    return 1
  fi
}

rollback_codex_after_recall_failure() {
  hooks_file="$1"
  hooks_backup="$2"
  hooks_existed="$3"
  mcp_preexisting="$4"
  config_backup="$5"
  rollback_failed=false

  if [[ "$connector_scopes_changed" == "true" ]]; then
    if ! stop_api_fail_closed \
      || ! restore_connector_config_backup "$config_backup" \
      || ! compose_cmd up -d --force-recreate api >/dev/null \
      || ! wait_for_api; then
      rollback_failed=true
    fi
  fi
  if ! rollback_codex_registration \
    "$hooks_file" "$hooks_backup" "$hooks_existed" "$mcp_preexisting"; then
    rollback_failed=true
  fi
  rm -f "$hooks_backup"
  if [[ "$rollback_failed" == "false" ]]; then
    rm -f "$config_backup"
    return 0
  fi
  return 1
}

connect_codex() {
  auto_recall_requested=true
  case "${1:-}" in
    --auto-recall) shift ;; # Backward-compatible explicit enable.
    --no-auto-recall) auto_recall_requested=false; shift ;;
  esac
  if (( $# > 0 )); then
    echo "usage: luthn connect codex [--no-auto-recall]" >&2
    return 2
  fi

  require_installation
  require_docker
  require_command curl
  require_command codex
  require_command python3

  if ! ensure_codex_connector_helper; then
    echo "Codex connector runtime is missing and could not be restored from the installed image revision." >&2
    return 1
  fi
  helper="$(codex_helper_path)"
  if ! report_pending_codex_disconnect; then
    echo "A previous Codex disconnect is still pending server observation; retry after the Luthn API is available." >&2
    return 1
  fi
  if [[ ! -x "$cli_path" ]]; then
    echo "Luthn CLI is not installed at $cli_path" >&2
    return 1
  fi

  if codex_mcp_registration_status; then
    mcp_preexisting=true
  else
    mcp_status=$?
    if [[ "$mcp_status" -eq 2 ]]; then
      echo "Codex already has an unrelated MCP registration named 'luthn'; no configuration was changed." >&2
      return 1
    fi
    mcp_preexisting=false
  fi

  hooks_file="$(codex_hooks_path)"
  instructions_file="$(codex_instructions_path)"
  hook_command="$(codex_hook_command)"
  ensure_directories
  hooks_backup="$(mktemp "$connector_state_dir/codex-hooks.XXXXXX")"
  hooks_existed=false
  if [[ -f "$hooks_file" ]]; then
    cp -p "$hooks_file" "$hooks_backup"
    hooks_existed=true
  fi

  if ! record_codex_connector_state \
    "$hooks_file" "$codex_pending_state_file" partial false false "$instructions_file"; then
    rm -f "$hooks_backup"
    echo "Codex connector ownership state could not be prepared; no configuration was changed." >&2
    return 1
  fi

  if ! python3 "$helper" hooks install \
    --path "$hooks_file" \
    --command "$hook_command"; then
    rm -f "$hooks_backup" "$codex_pending_state_file"
    return 1
  fi

  if [[ "$mcp_preexisting" == "false" ]]; then
    if ! codex mcp add luthn -- "$cli_path" mcp >/dev/null; then
      rollback_codex_registration "$hooks_file" "$hooks_backup" "$hooks_existed" true
      rm -f "$hooks_backup"
      return 1
    fi
  fi

  if ! mcp_probe="$(compose_cmd --profile tools run --rm --no-deps -T mcp mcp --list-tools 2>&1)" \
    || ! printf '%s\n' "$mcp_probe" | grep -q '^get_context_pack$'; then
    rollback_codex_registration "$hooks_file" "$hooks_backup" "$hooks_existed" "$mcp_preexisting"
    rm -f "$hooks_backup"
    echo "Codex MCP probe failed; Luthn rolled back the connector configuration." >&2
    return 1
  fi

  if ! config_backup="$(mktemp "${config_file}.codex-connect.XXXXXX")" \
    || ! cp -p "$config_file" "$config_backup"; then
    rm -f "${config_backup:-}"
    rollback_codex_registration "$hooks_file" "$hooks_backup" "$hooks_existed" "$mcp_preexisting"
    rm -f "$hooks_backup"
    echo "Codex connector authorization backup could not be created; Luthn rolled back the connector configuration." >&2
    return 1
  fi
  if ! ensure_connector_scopes; then
    rollback_codex_registration "$hooks_file" "$hooks_backup" "$hooks_existed" "$mcp_preexisting"
    rm -f "$hooks_backup" "$config_backup"
    echo "Codex connector authorization could not be configured; Luthn rolled back the connector configuration." >&2
    return 1
  fi
  if [[ "$connector_scopes_changed" == "true" ]]; then
    echo "Refreshing Luthn API authorization scopes..."
    if ! stop_api_fail_closed; then
      if ! restore_connector_config_backup "$config_backup"; then
        rollback_codex_registration "$hooks_file" "$hooks_backup" "$hooks_existed" "$mcp_preexisting"
        rm -f "$hooks_backup"
        echo "Codex connector setup stopped before API restart, and the previous configuration must be restored from: $config_backup" >&2
        return 1
      fi
      rollback_codex_registration "$hooks_file" "$hooks_backup" "$hooks_existed" "$mcp_preexisting"
      rm -f "$hooks_backup" "$config_backup"
      echo "Codex connector setup could not stop the API; Luthn restored the previous configuration." >&2
      return 1
    fi
    if ! compose_cmd up -d --force-recreate api >/dev/null || ! wait_for_api; then
      stop_api_fail_closed || true
      recovery_succeeded=true
      if ! restore_connector_config_backup "$config_backup" \
        || ! compose_cmd up -d --force-recreate api >/dev/null \
        || ! wait_for_api; then
        recovery_succeeded=false
        api_stop_confirmed=true
        if ! stop_api_fail_closed; then
          api_stop_confirmed=false
        fi
      fi
      rollback_codex_registration "$hooks_file" "$hooks_backup" "$hooks_existed" "$mcp_preexisting"
      rm -f "$hooks_backup"
      if [[ "$recovery_succeeded" == "true" ]]; then
        rm -f "$config_backup"
        echo "Codex connector authorization did not become ready; Luthn restored the previous API configuration." >&2
      elif [[ "$api_stop_confirmed" == "true" ]]; then
        echo "Codex connector authorization did not become ready. The API was stopped; restore the previous configuration from: $config_backup" >&2
      else
        echo "Codex connector authorization did not become ready, and Luthn could not confirm that the API stopped. Stop the API immediately and restore: $config_backup" >&2
      fi
      return 1
    fi
  fi
  auto_recall_enabled=false
  if python3 "$helper" instructions check --path "$instructions_file"; then
    auto_recall_enabled=true
  fi
  recall_error=""
  if [[ "$auto_recall_requested" == "true" ]]; then
    if ! python3 "$helper" instructions install --path "$instructions_file"; then
      recall_error="the lightweight recall instruction could not be installed"
    else
      auto_recall_enabled=true
    fi
  else
    if ! python3 "$helper" instructions remove --path "$instructions_file"; then
      recall_error="the lightweight recall instruction could not be removed"
    else
      auto_recall_enabled=false
    fi
  fi
  if [[ -n "$recall_error" ]]; then
    if rollback_codex_after_recall_failure \
      "$hooks_file" "$hooks_backup" "$hooks_existed" "$mcp_preexisting" "$config_backup"; then
      echo "Codex connector setup failed because $recall_error; Luthn restored the previous configuration." >&2
    else
      echo "Codex connector setup failed because $recall_error, and rollback was incomplete. Restore the previous configuration from: $config_backup" >&2
    fi
    return 1
  fi
  if ! record_codex_connector_state \
    "$hooks_file" "$codex_pending_state_file" configured false "$auto_recall_enabled" "$instructions_file" \
    || ! mv "$codex_pending_state_file" "$codex_state_file"; then
    echo "Codex is configured, but its pending ownership state could not be finalized. Run 'luthn disconnect codex' before uninstalling." >&2
    return 1
  fi
  rm -f "$config_backup"
  rm -f "$hooks_backup"
  if ! report_codex_observation \
    "automatic-ingestion:true:Unknown:Unknown:" \
    "mcp:true:Verified:Succeeded:" >/dev/null; then
    echo "warning: Codex is configured, but Luthn could not record the initial connection observation" >&2
  fi
  recall_status=disabled
  [[ "$auto_recall_enabled" == "true" ]] && recall_status=enabled

  cat <<EOF
Codex connector files are configured, but automatic memory capture is not ready yet.
  automatic ingestion: waiting for Codex hook trust
  MCP: configured and verified
  lightweight recall: $recall_status

Required one-time Codex security steps:
  1. Quit and reopen Codex.
  2. In a Codex message box, enter /hooks.
  3. Open Stop > luthn.agent-connector.v1 and choose Trust.
  4. Complete one Codex turn, then verify with:
     $cli_path connection status codex

Setup is complete only when automatic-ingestion reports Active.
EOF
}

show_codex_connection_status() {
  require_installation
  require_command python3
  if [[ -f "$codex_disconnect_pending_state_file" ]]; then
    if has_codex_connector_state; then
      rm -f "$codex_disconnect_pending_state_file"
    elif ! report_pending_codex_disconnect; then
      echo "warning: pending Codex disconnect status could not be reported" >&2
    fi
  fi
  helper="$(codex_helper_path)"
  hooks_file="$(codex_state_value HOOKS_FILE)"
  [[ -n "$hooks_file" ]] || hooks_file="$(codex_hooks_path)"
  hook_command="$(codex_hook_command)"
  instructions_file="$(codex_state_value INSTRUCTIONS_FILE)"
  [[ -n "$instructions_file" ]] || instructions_file="$(codex_instructions_path)"

  if [[ -f "$codex_state_file" ]]; then
    echo "Local connector: configured"
  else
    echo "Local connector: not configured"
  fi

  if [[ -f "$helper" ]] && python3 "$helper" hooks check \
    --path "$hooks_file" \
    --command "$hook_command"; then
    echo "  automatic-ingestion: configured"
  else
    echo "  automatic-ingestion: missing"
  fi

  if command -v codex >/dev/null 2>&1 && codex_mcp_registration_status; then
    echo "  mcp: configured"
  else
    echo "  mcp: missing or changed"
  fi

  if [[ -f "$helper" ]] && python3 "$helper" instructions check --path "$instructions_file"; then
    echo "  lightweight-recall: enabled"
  else
    echo "  lightweight-recall: disabled"
  fi

  service_token_file="$(read_config LUTHN_SERVICE_TOKEN_FILE "$token_file")"
  base_url="$(read_config LUTHN_BASE_URL http://127.0.0.1:8080)"
  if [[ -f "$helper" && -f "$service_token_file" ]]; then
    if ! server_status="$(python3 "$helper" status \
      --base-url "$base_url" \
      --token-file "$service_token_file" \
      --agent-id codex)"; then
      echo "Server observation: unavailable"
    else
      printf '%s\n' "$server_status"
      if ! printf '%s\n' "$server_status" | grep -q '^  automatic-ingestion: Active'; then
        cat <<EOF
Automatic memory capture is not active yet.
  Restart Codex, enter /hooks, trust Stop > luthn.agent-connector.v1,
  then complete one Codex turn and run this status command again.
EOF
      fi
    fi
  else
    echo "Server observation: unavailable"
  fi
}

disconnect_codex() {
  require_installation
  require_command python3
  if [[ -f "$codex_disconnect_pending_state_file" ]] \
    && ! has_codex_connector_state \
    && ! command -v codex >/dev/null 2>&1; then
    if report_pending_codex_disconnect; then
      echo "Luthn-owned Codex connector configuration was removed."
    else
      echo "warning: Codex is disconnected locally, but the server observation is still pending" >&2
    fi
    return 0
  fi
  require_command codex
  helper="$(codex_helper_path)"
  if [[ ! -f "$helper" ]]; then
    if ! ensure_codex_connector_helper; then
      echo "Codex connector runtime is missing and could not be restored from the installed image revision." >&2
      return 1
    fi
    helper="$(codex_helper_path)"
  fi

  hooks_file="$(codex_state_value HOOKS_FILE)"
  [[ -n "$hooks_file" ]] || hooks_file="$(codex_hooks_path)"
  instructions_file="$(codex_state_value INSTRUCTIONS_FILE)"
  [[ -n "$instructions_file" ]] || instructions_file="$(codex_instructions_path)"
  ensure_directories
  hooks_backup="$(mktemp "$connector_state_dir/codex-hooks.XXXXXX")"
  hooks_existed=false
  if [[ -f "$hooks_file" ]]; then
    cp -p "$hooks_file" "$hooks_backup"
    hooks_existed=true
  fi
  instructions_backup="$(mktemp "$connector_state_dir/codex-instructions.XXXXXX")"
  instructions_existed=false
  auto_recall_enabled=false
  if [[ -f "$instructions_file" ]]; then
    cp -p "$instructions_file" "$instructions_backup"
    instructions_existed=true
  fi
  if python3 "$helper" instructions check --path "$instructions_file"; then
    auto_recall_enabled=true
  fi

  mcp_changed=false
  mcp_registered=false
  if codex_mcp_registration_status; then
    mcp_registered=true
  else
    mcp_status=$?
    if [[ "$mcp_status" -eq 2 ]]; then
      mcp_changed=true
      echo "warning: the 'luthn' MCP registration changed after setup and was preserved" >&2
    fi
  fi

  if ! record_codex_connector_state \
    "$hooks_file" "$codex_disconnect_pending_state_file" pending-disconnect "$mcp_changed" \
    "$auto_recall_enabled" "$instructions_file"; then
    rm -f "$hooks_backup" "$instructions_backup"
    echo "Codex disconnect state could not be prepared; no configuration was changed." >&2
    return 1
  fi

  if ! python3 "$helper" instructions remove --path "$instructions_file"; then
    rm -f "$codex_disconnect_pending_state_file" "$hooks_backup" "$instructions_backup"
    return 1
  fi

  if ! python3 "$helper" hooks remove --path "$hooks_file"; then
    restore_hooks_backup "$instructions_file" "$instructions_backup" "$instructions_existed"
    rm -f "$codex_disconnect_pending_state_file" "$hooks_backup" "$instructions_backup"
    return 1
  fi

  if [[ "$mcp_registered" == "true" ]] && ! codex mcp remove luthn >/dev/null; then
    restore_hooks_backup "$hooks_file" "$hooks_backup" "$hooks_existed"
    restore_hooks_backup "$instructions_file" "$instructions_backup" "$instructions_existed"
    rm -f "$codex_disconnect_pending_state_file" "$hooks_backup" "$instructions_backup"
    return 1
  fi

  rm -f "$codex_state_file" "$codex_pending_state_file" "$hooks_backup" "$instructions_backup"
  if ! report_pending_codex_disconnect; then
    echo "warning: Codex is disconnected locally, but the server observation is pending and will be retried" >&2
  fi
  echo "Luthn-owned Codex connector configuration was removed."
}

run_codex_hook() {
  helper="$(codex_helper_path)"
  [[ -f "$helper" && -f "$config_file" ]] || return 0
  command -v python3 >/dev/null 2>&1 || return 0
  service_token_file="$(read_config LUTHN_SERVICE_TOKEN_FILE "$token_file")"
  managed_operator_token_file="$(read_config LUTHN_OPERATOR_TOKEN_FILE "$operator_token_file")"
  base_url="$(read_config LUTHN_BASE_URL http://127.0.0.1:8080)"
  [[ -f "$service_token_file" ]] || return 0
  hook_args=("$helper" hook-run \
    --base-url "$base_url" \
    --token-file "$service_token_file" \
    --connector-version "$codex_connector_version")
  if [[ -f "$managed_operator_token_file" ]]; then
    hook_args+=(--excluded-token-file "$managed_operator_token_file")
  fi
  python3 "${hook_args[@]}" >/dev/null 2>&1 || true
}

stop_write_paths() {
  compose_cmd stop api >/dev/null 2>&1 || true
  for service in mcp adapter; do
    ids="$(docker ps -q \
      --filter "label=com.docker.compose.project=$project_name" \
      --filter "label=com.docker.compose.service=$service")"
    if [[ -n "$ids" ]]; then
      # shellcheck disable=SC2086
      docker stop $ids >/dev/null
    fi
  done
}

update_luthn() {
  require_installation
  require_docker
  require_command curl
  configured_image="$(read_config LUTHN_IMAGE "$default_image")"
  explicit_target=false
  if [[ -n "${1:-}" ]]; then
    target_image="$1"
    explicit_target=true
  else
    target_image="$configured_image"
  fi
  if [[ "$explicit_target" != "true" ]] && is_immutable_image_ref "$target_image"; then
    echo "Update stopped because the configured image is immutable: $target_image" >&2
    echo "Choose an explicit mutable channel or target: luthn update <image>" >&2
    return 2
  fi
  previous_ref="$(read_config LUTHN_IMAGE "$default_image")"
  previous_id="$(image_id_for_container)"
  previous_revision=""
  previous_mcp_schema=""
  if [[ -n "$previous_id" ]]; then
    previous_revision="$(docker image inspect --format '{{ index .Config.Labels "org.opencontainers.image.revision" }}' "$previous_id" 2>/dev/null || true)"
    previous_mcp_schema="$(image_label "$previous_id" io.luthn.mcp-schema.version)"
    if [[ -z "$previous_mcp_schema" ]] && command -v python3 >/dev/null 2>&1; then
      previous_mcp_schema="$(probe_image_mcp_schema_version "$previous_id" 2>/dev/null || true)"
    fi
  fi

  ensure_directories
  backup_path="$state_dir/backups/luthn-$(date -u +%Y%m%dT%H%M%SZ).dump"

  echo "Pulling $target_image..."
  if ! pull_image "$target_image"; then
    record_state failed "$target_image" "" "$previous_id"
    echo "Update failed while pulling the target image. The running API and previous image were preserved." >&2
    return 1
  fi

  target_id="$(docker image inspect --format '{{.Id}}' "$target_image")"
  target_revision="$(docker image inspect --format '{{ index .Config.Labels "org.opencontainers.image.revision" }}' "$target_image" 2>/dev/null || true)"
  target_mcp_schema="$(image_label "$target_id" io.luthn.mcp-schema.version)"
  if [[ -z "$target_mcp_schema" ]] && command -v python3 >/dev/null 2>&1; then
    target_mcp_schema="$(probe_image_mcp_schema_version "$target_id" 2>/dev/null || true)"
  fi
  if ! operator_credential_slot_available "$target_image"; then
    echo "Update stopped because the local operator credential could not be configured." >&2
    return 1
  fi
  if has_codex_connector_state && ! ensure_connector_scopes --check-only; then
    record_state failed "$target_image" "$target_id" "$previous_id"
    echo "Update stopped because the active Codex connector scopes could not be configured." >&2
    return 1
  fi
  runtime_rollback_dir="$(mktemp -d "$state_dir/runtime-update.XXXXXX")"
  cp -p "$compose_file" "$runtime_rollback_dir/compose.yaml"
  cp -p "$cli_path" "$runtime_rollback_dir/luthn"
  cp -p "$config_file" "$runtime_rollback_dir/luthn.env"
  previous_operator_token_file="$(read_config LUTHN_OPERATOR_TOKEN_FILE "$operator_token_file")"
  if [[ -f "$previous_operator_token_file" ]]; then
    cp -p "$previous_operator_token_file" "$runtime_rollback_dir/operator-token"
    operator_token_existed=true
  else
    operator_token_existed=false
  fi
  helper="$(codex_helper_path)"
  [[ -f "$helper" ]] && cp -p "$helper" "$runtime_rollback_dir/luthn-codex-connector.py"
  hooks_file=""
  instructions_file=""
  if has_codex_connector_state; then
    hooks_file="$(codex_state_value HOOKS_FILE)"
    [[ -n "$hooks_file" ]] || hooks_file="$(codex_hooks_path)"
    instructions_file="$(codex_state_value INSTRUCTIONS_FILE)"
    [[ -n "$instructions_file" ]] || instructions_file="$(codex_instructions_path)"
    [[ -f "$hooks_file" ]] && cp -p "$hooks_file" "$runtime_rollback_dir/hooks.json"
    [[ -f "$instructions_file" ]] && cp -p "$instructions_file" "$runtime_rollback_dir/AGENTS.md"
    [[ -f "$codex_state_file" ]] && cp -p "$codex_state_file" "$runtime_rollback_dir/codex.env"
    [[ -f "$codex_pending_state_file" ]] && cp -p "$codex_pending_state_file" "$runtime_rollback_dir/codex.pending.env"
  fi
  previous_connector_version="$(codex_state_value CONNECTOR_VERSION)"
  previous_helper_digest="$(codex_state_value HELPER_DIGEST)"
  previous_template_digest="$(codex_state_value TEMPLATE_DIGEST)"
  if has_codex_connector_state; then
    if ! ensure_connector_scopes; then
      cp -p "$runtime_rollback_dir/luthn.env" "$config_file"
      rm -rf "$runtime_rollback_dir"
      record_state failed "$target_image" "$target_id" "$previous_id"
      echo "Update stopped because the active Codex connector scopes could not be configured." >&2
      return 1
    fi
  elif ! ensure_access_request_scope; then
    echo "warning: access.request could not be added because the custom service-token scope table is full" >&2
  fi
  if ! ensure_operator_credential "$target_image"; then
    cp -p "$runtime_rollback_dir/luthn.env" "$config_file"
    if [[ "$operator_token_existed" == "true" ]]; then
      cp -p "$runtime_rollback_dir/operator-token" "$previous_operator_token_file"
    else
      rm -f "$previous_operator_token_file"
    fi
    rm -rf "$runtime_rollback_dir"
    record_state failed "$target_image" "$target_id" "$previous_id"
    echo "Update stopped because the local operator credential could not be configured." >&2
    return 1
  fi
  echo "Refreshing lifecycle runtime..."
  if ! download_runtime "$(runtime_source_for_image "$target_image" "$target_revision")"; then
    cp -p "$runtime_rollback_dir/compose.yaml" "$compose_file"
    cp -p "$runtime_rollback_dir/luthn" "$cli_path"
    if [[ -f "$runtime_rollback_dir/luthn-codex-connector.py" ]]; then
      cp -p "$runtime_rollback_dir/luthn-codex-connector.py" "$helper"
    else
      rm -f "$helper"
    fi
    cp -p "$runtime_rollback_dir/luthn.env" "$config_file"
    if [[ "$operator_token_existed" == "true" ]]; then
      cp -p "$runtime_rollback_dir/operator-token" "$previous_operator_token_file"
    else
      rm -f "$previous_operator_token_file"
    fi
    rm -rf "$runtime_rollback_dir"
    record_state failed "$target_image" "$target_id" "$previous_id"
    echo "Update failed while downloading lifecycle runtime. The running API and previous image were preserved." >&2
    return 1
  fi
  if has_codex_connector_state && ! reconcile_codex_managed_configuration; then
    cp -p "$runtime_rollback_dir/compose.yaml" "$compose_file"
    cp -p "$runtime_rollback_dir/luthn" "$cli_path"
    if [[ -f "$runtime_rollback_dir/luthn-codex-connector.py" ]]; then
      cp -p "$runtime_rollback_dir/luthn-codex-connector.py" "$helper"
    else
      rm -f "$helper"
    fi
    if [[ -f "$runtime_rollback_dir/hooks.json" ]]; then
      cp -p "$runtime_rollback_dir/hooks.json" "$hooks_file"
    else
      rm -f "$hooks_file"
    fi
    if [[ -f "$runtime_rollback_dir/AGENTS.md" ]]; then
      cp -p "$runtime_rollback_dir/AGENTS.md" "$instructions_file"
    else
      rm -f "$instructions_file"
    fi
    if [[ -f "$runtime_rollback_dir/codex.env" ]]; then
      cp -p "$runtime_rollback_dir/codex.env" "$codex_state_file"
    else
      rm -f "$codex_state_file"
    fi
    if [[ -f "$runtime_rollback_dir/codex.pending.env" ]]; then
      cp -p "$runtime_rollback_dir/codex.pending.env" "$codex_pending_state_file"
    else
      rm -f "$codex_pending_state_file"
    fi
    cp -p "$runtime_rollback_dir/luthn.env" "$config_file"
    if [[ "$operator_token_existed" == "true" ]]; then
      cp -p "$runtime_rollback_dir/operator-token" "$previous_operator_token_file"
    else
      rm -f "$previous_operator_token_file"
    fi
    rm -rf "$runtime_rollback_dir"
    record_state failed "$target_image" "$target_id" "$previous_id"
    echo "Update failed while reconciling the Codex connector. Runtime and managed Codex configuration were restored." >&2
    return 1
  fi
  compatibility_changed=false
  if has_codex_connector_state; then
    current_connector_version="$(codex_state_value CONNECTOR_VERSION)"
    current_helper_digest="$(codex_state_value HELPER_DIGEST)"
    current_template_digest="$(codex_state_value TEMPLATE_DIGEST)"
    if [[ "$previous_connector_version" != "$current_connector_version" \
      || "$previous_helper_digest" != "$current_helper_digest" \
      || "$previous_template_digest" != "$current_template_digest" \
      || "$previous_mcp_schema" != "$target_mcp_schema" ]]; then
      compatibility_changed=true
      current_digest_mode=legacy
      if [[ "$current_helper_digest" =~ ^[0-9a-f]{64}$ \
        && "$current_template_digest" =~ ^[0-9a-f]{64}$ ]]; then
        current_digest_mode=modern
      fi
      if ! record_codex_connector_state \
        "$hooks_file" "$codex_state_file" configured true \
        "$(codex_state_value AUTO_RECALL)" "$instructions_file" \
        "$current_connector_version" "$current_helper_digest" \
        "$current_template_digest" "$current_digest_mode"; then
        cp -p "$runtime_rollback_dir/compose.yaml" "$compose_file"
        cp -p "$runtime_rollback_dir/luthn" "$cli_path"
        if [[ -f "$runtime_rollback_dir/luthn-codex-connector.py" ]]; then
          cp -p "$runtime_rollback_dir/luthn-codex-connector.py" "$helper"
        else
          rm -f "$helper"
        fi
        [[ -f "$runtime_rollback_dir/hooks.json" ]] \
          && cp -p "$runtime_rollback_dir/hooks.json" "$hooks_file" \
          || rm -f "$hooks_file"
        [[ -f "$runtime_rollback_dir/AGENTS.md" ]] \
          && cp -p "$runtime_rollback_dir/AGENTS.md" "$instructions_file" \
          || rm -f "$instructions_file"
        [[ -f "$runtime_rollback_dir/codex.env" ]] \
          && cp -p "$runtime_rollback_dir/codex.env" "$codex_state_file" \
          || rm -f "$codex_state_file"
        [[ -f "$runtime_rollback_dir/codex.pending.env" ]] \
          && cp -p "$runtime_rollback_dir/codex.pending.env" "$codex_pending_state_file" \
          || rm -f "$codex_pending_state_file"
        cp -p "$runtime_rollback_dir/luthn.env" "$config_file"
        if [[ "$operator_token_existed" == "true" ]]; then
          cp -p "$runtime_rollback_dir/operator-token" "$previous_operator_token_file"
        else
          rm -f "$previous_operator_token_file"
        fi
        rm -rf "$runtime_rollback_dir"
        record_state failed "$target_image" "$target_id" "$previous_id"
        echo "Update failed while recording the Codex compatibility notice. Runtime and managed configuration were restored." >&2
        return 1
      fi
    fi
  fi
  rm -rf "$runtime_rollback_dir"

  compose_cmd up -d postgres
  wait_for_postgres
  echo "Stopping API and MCP write paths..."
  stop_write_paths
  if [[ -n "${LUTHN_UPDATE_AFTER_STOP_HOOK:-}" ]]; then
    "$LUTHN_UPDATE_AFTER_STOP_HOOK"
  fi
  echo "Backing up PostgreSQL to $backup_path..."
  umask 077
  if ! compose_cmd exec -T postgres pg_dump \
    -U "$(read_config POSTGRES_USER luthn)" \
    -d "$(read_config POSTGRES_DB luthn)" \
    -Fc >"$backup_path"; then
    rm -f "$backup_path"
    recovery_ref="$previous_ref"
    [[ -n "$previous_id" ]] && recovery_ref="$previous_id"
    set_config LUTHN_IMAGE "$recovery_ref"
    record_state failed "$recovery_ref" "$previous_id" "$previous_id"
    if ! compose_cmd up -d api; then
      echo "Update failed while backing up PostgreSQL, and the previous API could not be restarted." >&2
    else
      echo "Update failed while backing up PostgreSQL. The previous API was restarted." >&2
    fi
    return 1
  fi
  record_state updating "$target_image" "$target_id" "$previous_id" "$backup_path"

  set_config LUTHN_IMAGE "$target_image"
  echo "Applying target-image migrations..."
  if ! compose_cmd run --rm --no-deps migrate; then
    [[ -n "$previous_id" ]] && set_config LUTHN_IMAGE "$previous_id" || set_config LUTHN_IMAGE "$previous_ref"
    record_state failed "$target_image" "$target_id" "$previous_id" "$backup_path"
    echo "Update failed during migration. API remains stopped; use the recorded backup and previous image for recovery." >&2
    return 1
  fi

  compose_cmd up -d api
  if ! wait_for_api; then
    stop_write_paths
    [[ -n "$previous_id" ]] && set_config LUTHN_IMAGE "$previous_id" || set_config LUTHN_IMAGE "$previous_ref"
    record_state failed "$target_image" "$target_id" "$previous_id" "$backup_path"
    echo "Update failed readiness. API is stopped; the backup and previous image ID are recorded." >&2
    return 1
  fi

  current_id="$(image_id_for_container)"
  record_state ready "$target_image" "$current_id" "$previous_id" "$backup_path"
  refresh_codex_connection_observation || \
    echo "warning: updated Codex connector status could not be reported" >&2
  echo "Luthn update completed: $target_image"
  echo "Revision: ${previous_revision:-unavailable} -> ${target_revision:-unavailable}"
  if [[ "$compatibility_changed" == "true" ]]; then
    echo "Restart required: Luthn MCP compatibility changed (${previous_mcp_schema:-unknown} -> ${target_mcp_schema:-$mcp_schema_version})."
    echo "Agent notice: restart the current Codex host before invoking Luthn tools again."
  fi
}

reset_luthn() {
  if [[ "${1:-}" != "--yes" ]]; then
    echo "usage: luthn reset --yes" >&2
    echo "This permanently deletes the Luthn PostgreSQL and operator volumes." >&2
    exit 2
  fi
  require_installation
  require_docker
  compose_cmd down --volumes --remove-orphans
  docker volume rm \
    "$(read_config LUTHN_POSTGRES_VOLUME luthn-postgres)" \
    "$(read_config LUTHN_OPERATOR_VOLUME luthn-operator)" >/dev/null 2>&1 || true
  start_stack true
  current_id="$(image_id_for_container)"
  record_state ready "$(read_config LUTHN_IMAGE "$default_image")" "$current_id"
  refresh_codex_connection_observation || \
    echo "warning: reset completed, but Codex connector status could not be reported" >&2
  echo "Luthn data was reset and the stack is ready."
}

uninstall_luthn() {
  purge_data=false
  confirmed=false
  while (( $# > 0 )); do
    case "$1" in
      --purge-data) purge_data=true ;;
      --yes) confirmed=true ;;
      *) echo "unknown uninstall option: $1" >&2; exit 2 ;;
    esac
    shift
  done

  if [[ "$purge_data" == "true" && "$confirmed" != "true" ]]; then
    echo "usage: luthn uninstall --purge-data --yes" >&2
    echo "Purging persistent data requires both flags." >&2
    exit 2
  fi

  require_docker
  if has_codex_connector_artifact; then
    if ! disconnect_codex; then
      echo "Uninstall stopped because Codex connector cleanup did not complete." >&2
      echo "Restore Codex prerequisites, run 'luthn disconnect codex', and retry." >&2
      return 1
    fi
  fi
  if [[ -f "$compose_file" && -f "$config_file" ]]; then
    if [[ "$purge_data" == "true" ]]; then
      compose_cmd down --volumes --remove-orphans
    else
      compose_cmd down --remove-orphans
    fi
  fi

  if [[ "$purge_data" == "true" ]]; then
    docker volume rm \
      "$(read_config LUTHN_POSTGRES_VOLUME luthn-postgres)" \
      "$(read_config LUTHN_OPERATOR_VOLUME luthn-operator)" >/dev/null 2>&1 || true
    rm -rf "$data_dir" "$config_dir" "$state_dir"
    echo "Luthn services, persistent data, configuration, backups, and runtime were removed."
  else
    rm -rf "$data_dir"
    echo "Luthn services and runtime were removed. Data volumes, configuration, and backups were preserved."
  fi
  rm -f "$cli_path"
}

run_adapter() {
  require_installation
  require_docker
  compose_cmd --profile tools run --rm --no-deps -T adapter
}

run_mcp() {
  require_installation
  require_docker
  if (( $# == 0 )); then
    if [[ -f "$codex_state_file" ]] && command -v python3 >/dev/null 2>&1; then
      report_codex_observation "mcp:true:Verified:Succeeded:" >/dev/null 2>&1 || true
    fi
    if ! compose_cmd --profile tools run --rm --no-deps -T mcp; then
      if [[ -f "$codex_state_file" ]] && command -v python3 >/dev/null 2>&1; then
        report_codex_observation "mcp:true:Verified:Failed:mcp.launch_failed" >/dev/null 2>&1 || true
      fi
      return 1
    fi
  else
    if compose_cmd --profile tools run --rm --no-deps -T mcp mcp "$@"; then
      if [[ -f "$codex_state_file" ]] && command -v python3 >/dev/null 2>&1; then
        report_codex_observation "mcp:true:Verified:Succeeded:" >/dev/null 2>&1 || true
      fi
    else
      if [[ -f "$codex_state_file" ]] && command -v python3 >/dev/null 2>&1; then
        report_codex_observation "mcp:true:Verified:Failed:mcp.probe_failed" >/dev/null 2>&1 || true
      fi
      return 1
    fi
  fi
}

command="${1:-help}"
case "$command" in
  install) shift; install_luthn "$@" ;;
  version) shift; show_version "$@" ;;
  status|check) show_status ;;
  update)
    shift
    if [[ "${1:-}" == "check" ]]; then
      shift
      check_for_update "$@"
    else
      (( $# <= 1 )) || { echo "usage: luthn update [image]" >&2; exit 2; }
      update_luthn "${1:-}"
    fi
    ;;
  doctor) shift; show_doctor "$@" ;;
  reset) shift; reset_luthn "${1:-}" ;;
  uninstall) shift; uninstall_luthn "$@" ;;
  connect)
    shift
    [[ "${1:-}" == "codex" ]] || { echo "usage: luthn connect codex [--no-auto-recall]" >&2; exit 2; }
    shift
    connect_codex "$@"
    ;;
  connection)
    shift
    [[ "${1:-}" == "status" && "${2:-}" == "codex" ]] || {
      echo "usage: luthn connection status codex" >&2
      exit 2
    }
    show_codex_connection_status
    ;;
  disconnect)
    shift
    [[ "${1:-}" == "codex" ]] || { echo "usage: luthn disconnect codex" >&2; exit 2; }
    disconnect_codex
    ;;
  codex-hook) run_codex_hook ;;
  adapter) run_adapter ;;
  mcp) shift; run_mcp "$@" ;;
  help|-h|--help) print_usage ;;
  *) echo "unknown command: $command" >&2; print_usage >&2; exit 2 ;;
esac
